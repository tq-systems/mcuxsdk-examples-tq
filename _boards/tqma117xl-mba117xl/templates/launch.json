{
  "inputs": [
    {
      "type": "pickString",
      "id": "app",
      "description": "choose your app",
      "options": [
        "hello_world",
        "led_blinky"
      ]
    }
  ],
  "configurations": [
    {
      "showDevDebugOutput": "both",
      "type": "cortex-debug",
      "request": "launch",
      "name": "Load into ram",
      "cwd": "${workspaceFolder}",
      "servertype": "jlink",
      "device": "MIMXRT1176xxxA_M7",
      "interface": "jtag",
      "runToEntryPoint": "main",
      "executable": "${workspaceFolder}/../../../build/${input:app}_cm7.elf",
      "serverArgs": [
        "-endian",
        "little",
        "-LocalhostOnly",
        "-speed",
        "4000"
      ],
      "postLaunchCommands": [
        "target remote localhost:50000",
        "monitor reset",
        "monitor halt",
        "load"
      ]
    },
  ]
}
